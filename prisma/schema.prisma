generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Problem {
  id           String               @id @default(uuid())
  slug         String               @unique
  difficulty   Difficulty
  isPublished  Boolean              @default(true)
  translations ProblemTranslation[]
  testCases    TestCase[]
  submissions  Submission[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model ProblemTranslation {
  id          String   @id @default(uuid())
  problemId   String
  locale      Locale
  title       String
  description String
  examples    Json
  constraints Json
  starterCode Json
  tags        String[]

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, locale])
}

enum Locale {
  RU
  EN
}

model TestCase {
  id        String  @id @default(uuid())
  problemId String
  input     String
  output    String
  isHidden  Boolean @default(true)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id        String           @id @default(uuid())
  problemId String
  language  String
  code      String
  status    SubmissionStatus
  result    Json?
  createdAt DateTime         @default(now())

  problem Problem @relation(fields: [problemId], references: [id])
}

enum SubmissionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT
}

// Dashboard
enum AdminRole {
  SUPER_ADMIN // Full access
  ADMIN // Manage tasks && users
  EDITOR // Only Tasks
  VIEWER // Only view analytics
}

model AdminUser {
  id        String    @id @default(uuid())
  login     String    @unique
  password  String
  name      String
  role      AdminRole @default(EDITOR)
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  AuditAdminLog AuditAdminLog[]

  @@map("admin_user")
}

model AuditAdminLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String // CREATE_PROBLEM, UPDATE_PROBLEM, DELETE_SUBMISSION
  entityType String   @map("entity_type") // Problem, Submission, TestCase
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAdress   String?  @map("ip_adress")
  userAgent  String?  @map("users_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@map("audit_admin_log")
}
